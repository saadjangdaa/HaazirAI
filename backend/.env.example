GEMINI_API_KEY=your_gemini_api_key
# Alternative name (supported by config.py):
# GOOGLE_GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GOOGLE_MAPS_API_KEY=your_maps_api_key

# Firestore (backend Admin SDK) — required for real CRUD (not mock mode)
FIREBASE_PROJECT_ID=your_firebase_project_id
# Service account JSON (do not commit). Common filenames:
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# FIREBASE_CREDENTIALS_PATH=./firebase-key.json

# Cloud deployments (Render, Railway, etc.) — paste entire service account JSON here.
# This is used instead of a file since ephemeral filesystems don't persist uploads.
# On Render: add this as an env var in the dashboard, paste the full JSON as the value.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n..."}

# FCM (Phase 3 — push notifications)
# FCM_SERVER_KEY=optional_legacy
# EXPO_ACCESS_TOKEN=optional_for_expo_push_api

ENVIRONMENT=development
PORT=8080

# Phase 6 — scheduled reminder delivery (production cron)
# CRON_SECRET=long-random-string-for-cron-http-header
# NOTIFICATION_CRON_INTERVAL_SECONDS=300
# NOTIFICATION_CRON_INTERNAL=false
