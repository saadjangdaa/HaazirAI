{
  "expo": {
    "name": "Haazir AI",
    "slug": "haazir-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A6FFF"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A6FFF"
      },
      "package": "com.haazir.ai",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBrk1qwmRpVbhH_URNwS_d0P8iVuRCFzoM"
        }
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.haazir.ai",
      "config": {
        "googleMapsApiKey": "AIzaSyBrk1qwmRpVbhH_URNwS_d0P8iVuRCFzoM"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Haazir AI ko awaz sun'ne ke liye microphone chahiye",
        "NSCameraUsageDescription": "CNIC verification ke liye camera chahiye",
        "NSPhotoLibraryUsageDescription": "CNIC ki photo upload karne ke liye gallery chahiye",
        "NSLocationWhenInUseUsageDescription": "Haazir AI aapke qareeb service providers dhundne ke liye location use karta hai",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Haazir AI aapke qareeb service providers dhundne ke liye location use karta hai"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Haazir AI aapke qareeb service providers dhundne ke liye location use karta hai"
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyBrk1qwmRpVbhH_URNwS_d0P8iVuRCFzoM"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "CNIC verification ke liye gallery access chahiye",
          "cameraPermission": "CNIC ki photo lene ke liye camera chahiye"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Haazir AI ko awaz sun'ne ke liye microphone chahiye"
        }
      ],
      "expo-notifications",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1A6FFF"
        }
      ]
    ],
    "scheme": "haazir",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5248e7f0-9a27-45bd-9fe3-c3dafde66eab"
      }
    },
    "owner": "saadabdus"
  }
}
