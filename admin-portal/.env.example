VITE_API_BASE_URL=https://haazirai-backend2.onrender.com
# Local backend example:
# VITE_API_BASE_URL=http://localhost:8080

# Dev login without Firebase (empty email/password on login page)
VITE_DEV_LOGIN=true
VITE_ADMIN_DEV_UID=dev_super_admin

